0145                  00508 ACTUATOR_MOTOR_STOP
0145   0020           00509     BANKSEL     STOP_COUNT
0146   082D           00510     MOVFW       STOP_COUNT
0147   0020           00511     BANKSEL     ACTUATOR_MOTOR_STATUS
0148   00B3           00512     MOVWF       ACTUATOR_MOTOR_STATUS
0149                  00513 DETERMINE_ACTUATOR_STATE_END
0149   0008           00514     RETURN
