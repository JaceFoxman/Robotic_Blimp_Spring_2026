                      00472    
                      00473 ;*******************************************************************************************************
                            **
                      00474 ;*** DETERMINE_ACUTATOR_STATE will run every time a full 4 byte I2C Packet is received.  This function *
                            **
                      00475 ;***  Will compare joystick to threshholds and set the actuator output status count accoridingly.      *
                            **
                      00476 ;***   This template uses joystick 2 left and right action as an example.  If Joystick 2 is above the  *
                            **
                      00477 ;***   threshhold actuator motor is moves forward, below the threshold actuator motor moves reverse.   *
                            **
                      00478 ;***   If it is neither above or below, actuator motor is set to stop.                                 *
                            **
                      00479 ;*******************************************************************************************************
                            ** 
012C                  00480 DETERMINE_ACTUATOR_STATE
012C   0020           00481     BANKSEL     UPPER_THRESHOLD
012D   0830           00482     MOVFW       UPPER_THRESHOLD
012E   0020           00483     BANKSEL     JOY2_LR
012F   0225           00484     SUBWF       JOY2_LR,0               ;Subtract Upper Threshold from Joystick Value (Stored in W)
0130   0020           00485     BANKSEL     STATUS                  ;JOY2_LR - UPPER_THRESHOLD
0131   1803           00486     BTFSC       STATUS,0
0132   2???           00487     GOTO        ACTUATOR_MOTOR_FORWARD  ;Result is Positive Joystick is above Threshold
0133   0020           00488     BANKSEL     LOWER_THRESHOLD
0134   0831           00489     MOVFW       LOWER_THRESHOLD
0135   0020           00490     BANKSEL     JOY2_LR
0136   0225           00491     SUBWF       JOY2_LR,0               ;Subtract Lower Threshold from Joystick Value (Stored in W)
0137   0020           00492     BANKSEL     STATUS                  ;JOY2_LR - LOWER_THRESHOLD
0138   1C03           00493     BTFSS       STATUS,0
0139   2???           00494     GOTO        ACTUATOR_MOTOR_REVERSE  ;Result is Negative Joystick is below Threshold
013A   2???           00495     GOTO        ACTUATOR_MOTOR_STOP     ;Joystick is Neither above or below thresholds
013B                  00496 ACTUATOR_MOTOR_FORWARD
013B   0020           00497     BANKSEL     FORWARD_COUNT
013C   082C           00498     MOVFW       FORWARD_COUNT
013D   0020           00499     BANKSEL     ACTUATOR_MOTOR_STATUS
013E   00B3           00500     MOVWF       ACTUATOR_MOTOR_STATUS
013F   2???           00501     GOTO        DETERMINE_ACTUATOR_STATE_END
0140                  00502 ACTUATOR_MOTOR_REVERSE
0140   0020           00503     BANKSEL     REVERSE_COUNT
0141   082E           00504     MOVFW       REVERSE_COUNT
0142   0020           00505     BANKSEL     ACTUATOR_MOTOR_STATUS
0143   00B3           00506     MOVWF       ACTUATOR_MOTOR_STATUS
