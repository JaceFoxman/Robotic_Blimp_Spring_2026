                      00119 ;*****************************************************************************************************
                      00120 ;*** TMR2_INTERRUPT Hanldles the Servo Signal Outputs.  Every 20mS All the outputs are set         ***
                      00121 ;*** and their corresponding counters are reset to their on-time "status" count.                   ***
                      00122 ;*** When 20mS has not passed, each output counter is decremented.  If the count reaches 0         ***
                      00123 ;*** the output is cleared.  Outputs 1-8 are on Port A; Output 9 is PortC,0; Output 10 is PortC,5. ***
                      00124 ;*** Right Motor is Output 1.  Left Motor is Output 2. Acutator Motor is Output 3.                 ***
                      00125 ;*****************************************************************************************************
0018                  00126 TMR2_INTERRUPT
0018   0020           00127     BANKSEL     T20MS_COUNT_1
0019   3000           00128     MOVLW       H'00'
001A   0227           00129     SUBWF       T20MS_COUNT_1,0
001B   0020           00130     BANKSEL     STATUS
001C   1903           00131     BTFSC       STATUS,2
001D   2???           00132     GOTO        FIRST_COUNT_ZERO
Message[305]: Using default destination of 1 (file).
