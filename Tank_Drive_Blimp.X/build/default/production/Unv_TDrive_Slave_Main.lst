                      00324 ;*******************************************************************************************************
                            ***
                      00325 ;*** SET_DRIVE_STATE will run every time a full 4 byte I2C Packet is received.  This function will      
                            ***
                      00326 ;***   Inspect the status of CURRENT_DRIVE_STATE to determine motor function.  It will then update      
                            ***
                      00327 ;***    the outputs through setting Right and Left Motor Status Counts. See CURRENT_DRIVE_STATE bit map 
                            ***
                      00328 ;*******************************************************************************************************
                            *** 
00AA                  00329 SET_DRIVE_STATE
                      00330     ;Check CURRENT_DRIVE_STATE to determine drive mode.  
00AA   0020           00331     BANKSEL     CURRENT_DRIVE_STATE
00AB   3000           00332     MOVLW       H'00'
00AC   022F           00333     SUBWF       CURRENT_DRIVE_STATE,0
00AD   0020           00334     BANKSEL     STATUS
00AE   1903           00335     BTFSC       STATUS,2
00AF   2???           00336     GOTO        BOTH_STOP                   ;Current Mode is Stop
00B0   0020           00337     BANKSEL     CURRENT_DRIVE_STATE
00B1   3011           00338     MOVLW       H'11'
00B2   022F           00339     SUBWF       CURRENT_DRIVE_STATE,0
00B3   0020           00340     BANKSEL     STATUS
00B4   1903           00341     BTFSC       STATUS,2
00B5   2???           00342     GOTO        BOTH_FORWARD                ;Current Mode is Drive Forward
00B6   0020           00343     BANKSEL     CURRENT_DRIVE_STATE
00B7   3022           00344     MOVLW       H'22'
00B8   022F           00345     SUBWF       CURRENT_DRIVE_STATE,0
00B9   0020           00346     BANKSEL     STATUS
00BA   1903           00347     BTFSC       STATUS,2
00BB   2???           00348     GOTO        BOTH_REVERSE                ;Current Mode is Drive Reverse
00BC   0020           00349     BANKSEL     CURRENT_DRIVE_STATE
00BD   3010           00350     MOVLW       H'10'
00BE   022F           00351     SUBWF       CURRENT_DRIVE_STATE,0
00BF   0020           00352     BANKSEL     STATUS
00C0   1903           00353     BTFSC       STATUS,2
00C1   2???           00354     GOTO        TURN_RIGHT_F                ;Current Mode is Turn Right Forward
