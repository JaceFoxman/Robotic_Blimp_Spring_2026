                      00516 ;******************************************
                      00517 ;Main Code
                      00518 ;******************************************
014A                  00519 MAIN
                      00520     ;************************************************************************************************
                      00521     ;*** UPDATE_DRIVE_STATUS will run every time a full 4 byte I2C Packet is received.  The flag  ***
                      00522     ;*** I2C_RX_COMPLETE Bit 0 is set within the I2C_RECEIVE function after the fourth data       ***
                      00523     ;*** byte is received.  See Unv_Slave_I2C_SetUp.inc                                           ***
                      00524     ;************************************************************************************************
014A   0020           00525     BANKSEL     I2C_RX_COMPLETE
014B   1847           00526     BTFSC       I2C_RX_COMPLETE,0
