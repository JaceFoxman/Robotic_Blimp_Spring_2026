                      00095 ;***************************************************************************************
                      00096 ;*** TMR2_INTERRUPT Does two things. 1. Tracks how long since last UART recieve      ***
                      00097 ;*** And 2. Delays I2C COM to send packets every 96mS                                ***
                      00098 ;***************************************************************************************
0018                  00099 TMR2_INTERRUPT
                      00100     
                      00101     ;***************************************************************************************
                      00102     ;**** CONNECT_CHK_COUNT is incremented and if it surpasses 15 a UART COM Timeout is  ***
                      00103     ;**** Identified.  This should result in a timeout of no UART RX in 0.5s             ***
                      00104     ;***************************************************************************************
0018   0020           00105     BANKSEL     CONNECT_CHK_COUNT
Message[305]: Using default destination of 1 (file).
0019   0AAF           00106     INCF        CONNECT_CHK_COUNT
001A   3010           00107     MOVLW       D'16'                   ;32mS * 16 = 0.522S Before Connection Error
001B   022F           00108     SUBWF       CONNECT_CHK_COUNT,0
001C   0020           00109     BANKSEL     STATUS
001D   1903           00110     BTFSC       STATUS,2
001E   2???           00111     GOTO        CONNECT_TIMEOUT         ;Connection Time out Occured (no UART RX in 0.5s)
                      00112     
                      00113     ;***************************************************************************************
                      00114     ;**** I2C_COM_DELAY is incremented until it surpases a count of 3.  When the count   ***
                      00115     ;**** reaches 3 the Flag to Decode UART Data is Set.  This should result in I2C Data ***
                      00116     ;**** transmitted every 96mS                                                         ***
MPASM 5.84               UNV_MASTER_MAIN.ASM   4-29-2026  14:26:15         PAGE 21


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00117     ;***************************************************************************************
001F   0020           00118     BANKSEL     I2C_COM_DELAY
Message[305]: Using default destination of 1 (file).
0020   0AB0           00119     INCF        I2C_COM_DELAY
0021   3003           00120     MOVLW       D'3'                    ;32mS * 3 = 96mS Per I2C COM Send
0022   0230           00121     SUBWF       I2C_COM_DELAY,0
0023   0020           00122     BANKSEL     STATUS
0024   1903           00123     BTFSC       STATUS,2
0025   2???           00124     GOTO        UPDATE_I2C              ;96mS Passed Clear Count and Upate Flag
0026   2???           00125     GOTO        TMR2_INTERRUPT_END      ;Timeout has not occured Exit Routine
                      00126     
                      00127     ;***************************************************************************************
                      00128     ;****UPDATE_I2C occurs when 96mS has Passed.  This will reset the delay count and    ***
                      00129     ;**** Set the flag to signal an I2C Send routine in Main Loop                        ***
                      00130     ;***************************************************************************************
0027                  00131 UPDATE_I2C
0027   0020           00132     BANKSEL     I2C_COM_DELAY
0028   01B0           00133     CLRF        I2C_COM_DELAY           ;Clear I2C Com Delay Count
0029   0020           00134     BANKSEL     NEW_RX_DATA
002A   14AE           00135     BSF         NEW_RX_DATA,1           ;Set Update I2C Flag
002B   2???           00136     GOTO        TMR2_INTERRUPT_END      ;Exit Routine
                      00137     
                      00138     ;***************************************************************************************
                      00139     ;**** CONNECT_TIMEOUT occurs when 0.5S has passed without UART receive. This signals ***
                      00140     ;**** that the master lost connection to the controller. Can Send "All Stop Command" ***
                      00141     ;***  to the slave boards (Note: This version of the code handles an All Stop on the ***
                      00142     ;***  slaves when they do not receive updated I2C; i.e. I2C COM Timeout on the slave)***
                      00143     ;***************************************************************************************
002C                  00144 CONNECT_TIMEOUT
002C   300F           00145     MOVLW       D'15'
002D   00AF           00146     MOVWF       CONNECT_CHK_COUNT       ;Reset Count to 15 so next itteration will timeout
002E   2???           00147     CALL        CONTROLLER_DISCONNECT   ;Run All stop Commands to slaves
002F                  00148 TMR2_INTERRUPT_END
002F   0008           00149     RETURN
                      00150 
0030                  00151 CONTROLLER_DISCONNECT  ;******Connection Timeout Occured.  Run Stop Functions******
                      00152     ;**** Here Add an All Stop Command to the slaves for UART Timeout ****
                      00153     ;**** i.e. Send Motor Stop VIA I2C to Peripheral Boards           ****
0030   0008           00154     RETURN
                      00155    
