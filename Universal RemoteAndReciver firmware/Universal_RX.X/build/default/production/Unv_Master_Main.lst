                      00043  
                      00044 ;****************************************************************************************
                      00045 ;****                   Data Pack from Universal Remote Control(URC)                  ***
                      00046 ;****************************************************************************************
                      00047 ;_______________________________________________________________________________________________________
                            _____________________________________
                      00048 ;| Sync  | Robot Address | Command |             Byte 1                 |            Byte 2             
                              |             Byte 3              |
                      00049 ;|0x24($)| Robot Address | 0x4A(J) | Joystick 1 Up-Down High Byte       | Joystick 1 Right-Left High Byt
                            e | Joystick 2 Up-Down High Byte    |
                      00050 ;|0x24($)| Robot Address | 0x6A(j) | Joystick 2 Right-Left High Byte    | Joystick 3 Up-Down High Byte  
                              | Joystick 3 Right-Left High Byte |
                      00051 ;|0x24($)| Robot Address | 0x42(B) | Button Data Byte 1                 | Button Data Byte 2            
                              | 0x00 (Not Used)                 |
                      00052 ;_______________________________________________________________________________________________________
                            _____________________________________
                      00053  
                      00054 ;****************************************************************************************
                      00055 ;****                           Button Data Bit Maps                                  ***
                      00056 ;****************************************************************************************
                      00057 ;_____________________________          _____________________________
                      00058 ;|    Button Data Byte 1     |          |     Button Data Byte 2    |
                      00059 ;| Bit   |      Button       |          |  Bit  |       Button      |
                      00060 ;|   0   | Down Face Button  |          |   0   | Joystick 3 Button |
                      00061 ;|   1   | Right Face Button |          |  1-7  |     Not Used      |
                      00062 ;|   2   | Left Face Button  |          _____________________________
                      00063 ;|   3   | Up Face Button    |
                      00064 ;|   4   | Left Bumper       |
                      00065 ;|   5   | Right Bumper      |
                      00066 ;|   6   | Joystick 1 Button |
                      00067 ;|   7   | Joystick 2 Button |
                      00068 ;_____________________________
                      00069  
                      00070 ;***************************************************************************************
                      00071 ;****UART_RX Function Should be Called when a Byte is Received From UART             ***
                      00072 ;****This Function will Determine the Byte Received, Verify Handshake and Address,   ***
                      00073 ;****Save the Received Byte into Temp Variables, and Set a flag to signal to Decode  ***
                      00074 ;***************************************************************************************
0000                  00075 UART_RX
0000   0020           00076  BANKSEL    BYTE_COUNT
0001   3000           00077  MOVLW      H'00'
0002   0220           00078  SUBWF      BYTE_COUNT,0            ;Subtract BYTE_COUNT - W; Result Store in W
0003   1903           00079  BTFSC      STATUS,2                ;Check Zero Bit.  1 if Zero; 0 if not Zero
0004   2???           00080  GOTO       BYTE_1                  ;First Received Byte Check for HandShake CHAR 
                      00081  
0005   3001           00082  MOVLW      H'01'
0006   0220           00083  SUBWF      BYTE_COUNT,0            ;Subtract BYTE_COUNT - W; Result Store in W
0007   1903           00084  BTFSC      STATUS,2                ;Check Zero Bit.  1 if Zero; 0 if not Zero
MPASM 5.84               UNV_MASTER_MAIN.ASM   4-29-2026  14:26:15         PAGE  9


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

