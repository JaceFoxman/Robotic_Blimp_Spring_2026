                      00182 ;********************************************************************************************
                      00183 ;****DECODE_URC Function Will Determine The Data Saved in Temporary "MEM_SAVE" Registers. ***
                      00184 ;**** This is Based on the 3rd Data Byte UART Received Known as "CURRENT_DATA_PACK"       ***
                      00185 ;**** See Data Pack Layout Above and Additional Materials for URC                         ***
                      00186 ;********************************************************************************************
0052                  00187 DECODE_URC ;***Decode Memory Save 1-3 From Command Byte***
0052   0020           00188  BANKSEL    CURRENT_DATA_PACK
0053   304A           00189  MOVLW      H'4A'                   ;ASCII "J"
0054   022A           00190  SUBWF      CURRENT_DATA_PACK,0     ;Subtract CURRENT_DATA_PACK - W; Result Store in W
0055   1903           00191  BTFSC      STATUS,2                ;Check Zero Bit.  1 if Zero; 0 if not Zero
0056   2???           00192  GOTO       JOYSTICK_DATA_1         ;Data is Joystick Data 1 Packet
                      00193  
0057   306A           00194  MOVLW      H'6A'                   ;ASCII "j"
0058   022A           00195  SUBWF      CURRENT_DATA_PACK,0     ;Subtract CURRENT_DATA_PACK - W; Result Store in W
0059   1903           00196  BTFSC      STATUS,2                ;Check Zero Bit.  1 if Zero; 0 if not Zero
005A   2???           00197  GOTO       JOYSTICK_DATA_2         ;Data is Joystick Data 2 Packet
                      00198  
005B   3042           00199  MOVLW      H'42'
005C   022A           00200  SUBWF      CURRENT_DATA_PACK,0     ;Subtract CURRENT_DATA_PACK - W; Result Store in W
005D   1903           00201  BTFSC      STATUS,2                ;Check Zero Bit.  1 if Zero; 0 if not Zero
005E   2???           00202  GOTO       BUTTON_DATA             ;Data is Button Data Packet
005F   2???           00203  GOTO       DECODE_URC_END          ;Data Pack Unkown Exit Routine (Should Not Happen)
                      00204  
0060                  00205 JOYSTICK_DATA_1
0060   0020           00206  BANKSEL    MEM_SAVE_1
0061   082B           00207  MOVFW      MEM_SAVE_1
0062   0020           00208  BANKSEL    JOY1_UD
0063   00A2           00209  MOVWF      JOY1_UD                 ;First Data Variable is Joystick 1 Up and Down
                      00210  
0064   0020           00211  BANKSEL    MEM_SAVE_2
0065   082C           00212  MOVFW      MEM_SAVE_2
0066   0020           00213  BANKSEL    JOY1_LR
0067   00A3           00214  MOVWF      JOY1_LR                 ;Second Data Variable is Joystick 1 Left and Right
                      00215  
0068   0020           00216  BANKSEL    MEM_SAVE_3
0069   082D           00217  MOVFW      MEM_SAVE_3
006A   0020           00218  BANKSEL    JOY2_UD
006B   00A4           00219  MOVWF      JOY2_UD                 ;Third Data Variable is Joystick 2 Up and Down
                      00220  
