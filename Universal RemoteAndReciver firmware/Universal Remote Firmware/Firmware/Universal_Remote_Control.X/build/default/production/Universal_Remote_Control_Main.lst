                      00022 ;       10.                                                                 *
                      00023 ;                                                                           *
                      00024 ;****************************************************************************
                      00025     
                      00026 ;******************************************             
                      00027 ;Define Constants
                      00028 ;******************************************
                      00029 #Define         BAUD            D'100'                  ;Desired Baud Rate in Kbps for I2C
                      00030 #Define         FOSC            D'16000'                ;Oscillator Clock in KHz This must be filled
                      00031     
                      00032 ;******************************************             
                      00033 ;Define Variable Registers
                      00034 ;******************************************
  00000020            00035 TIMERCOUNT          EQU         0X20        ;Register to Slow Timer 2 to 0.5s Interrupts
  00000021            00036 ROBOT_ADDR          EQU         0X21        ;Register for Saving the Robot Address
  00000022            00037 JOY_1_CMND          EQU         0X22        ;Register for Saving the First Joystick Data Packet Command
  00000023            00038 JOY_2_CMND          EQU         0X23        ;Register for Saving the Second Joystick Data Packet Command
  00000024            00039 BUTTONS_CMND        EQU         0X24        ;Register for Saving the Buttons Data Packet Command
                      00040 ;*******Button and Joysick Save Data Variables*********************************************************
  00000025            00041 JOYSTICK_1_UD       EQU         0X25        ;Save High Byte of Left Joystick Up Down Data
  00000026            00042 JOYSTICK_1_LR       EQU         0X26        ;Save High Byte of Left Joystick Left Right Data
  00000027            00043 JOYSTICK_2_UD       EQU         0X27        ;Save High Byte of Right Lower Joystick Up Down Data
  00000028            00044 JOYSTICK_2_LR       EQU         0X28        ;Save High Byte of Right Lower Joystick Left Right Data
  00000029            00045 JOYSTICK_3_UD       EQU         0X29        ;Save High Byte of Right Upper Joystick Up Down Data
  0000002A            00046 JOYSTICK_3_LR       EQU         0X2A        ;Save High Byte of Right Upper Joystick Left Right Data
  0000002B            00047 BUTTON_DATA_1       EQU         0X2B        ;Save Button Conditions for first 8 Buttons
  0000002C            00048 BUTTON_DATA_2       EQU         0X2C        ;Save Button Condition for the 9th Button
                      00049 ;*******Transmission Variables********************************************************
  0000002D            00050 TX_HANDSHAKE        EQU         0X2D        ;Register to Store the Handshake Character: $ (0x24)
  0000002E            00051 TX_ADDR             EQU         0X2E        ;Register to Store the Robot Address Used in Tranmission
  0000002F            00052 TX_CMND             EQU         0X2F        ;Register to Store the Command Used in Transmission
  00000030            00053 TX_DATA_1           EQU         0X30        ;Register to Store the First Data Byte in Transmission Packe
                            t
  00000031            00054 TX_DATA_2           EQU         0X31        ;Register to Store the Second Data Byte in Transmission Pack
                            et
  00000032            00055 TX_DATA_3           EQU         0X32        ;Register to Store the Third Data Byte in Transmission Packe
                            t
  00000033            00056 TX_COUNT            EQU         0X33        ;Register to Track Which Data Packet Should be Sent
                      00057 ;********ADC Channel Variables**************************************************************************
                            *
  00000034            00058 ANCH0               EQU         0X34        ;JOY1 UD\     
  00000035            00059 ANCH1               EQU         0X35        ;JOY1 LR \     
  00000036            00060 ANCH2               EQU         0X36        ;JOY2 UD  \ 
  00000037            00061 ANCH3               EQU         0X37        ;JOY2 LR   | Variables Used to Change the Analog Channel Sel
                            ection While Saving Result Formatting
  00000038            00062 ANCH4               EQU         0X38        ;JOY3 UD  / 
  00000039            00063 ANCH5               EQU         0X39        ;JOY3 LR /  
  0000003A            00064 ANCH_COUNT          EQU         0X3A        ;Keep Track of Which Analog Channel is Active
                      00065                     
                      00066 ;******************************************             
                      00067 ;Start of Setup File Code
                      00068 ;******************************************
                      00069 SETUP_CODE CODE
